# Distribution Ignore Configuration for WooCommerce for Japan
# This file specifies files and directories that should be excluded from WordPress.org distribution packages.
# Files and directories listed here will not be included when deploying to the WordPress plugin repository.
# This ensures that only production-ready files are distributed to end users.

# Directories
/.wordpress-org
/.vscode
/.git
/.github
/.claude
/bin
/node_modules
/vendor
/src
/docs
/tests
/test-results
/promotion-json

# Files
.DS_Store
.wp-env.json
.gitattributes
.distignore
.gitignore
.phpcs.xml.dist
.phpunit.xml.dist
.phpunit.result.cache
phpunit.xml.dist
playwright.config.ts
tsconfig.e2e.json
composer.json
composer.lock
package-lock.json
package.json
webpack.config.js
wordfence-vendor.txt
LICENSE
README.md
CLAUDE.md
SECURITY-FIX-PAIDY.md
SHORTCODE-CHECKOUT-VALIDATION-REPORT.md

# Source files (compiled output is sufficient for distribution)
*.scss

# Temporary files
temp-editor.json

