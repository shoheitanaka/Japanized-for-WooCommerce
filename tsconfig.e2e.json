{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": [ "ES2020", "DOM" ],
		"types": [ "node", "@playwright/test" ],
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"outDir": "./tests/e2e/.compiled"
	},
	"include": [ "tests/e2e/**/*.ts", "playwright.config.ts" ],
	"exclude": [ "node_modules" ]
}
